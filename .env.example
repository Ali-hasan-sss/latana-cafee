# MongoDB (required for admin auth + future CMS data)
MONGODB_URI=mongodb://127.0.0.1:27017/latana-cafe

# Signed admin session cookie (min 16 chars; use a long random string in production)
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Used only by `npm run seed:admin` (defaults shown if unset)
ADMIN_SEED_USERNAME=latanaAdmin
ADMIN_SEED_PASSWORD=admin123

# Table booking emails (Gmail: enable 2FA, then create an App Password under Google Account → Security)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-character-app-password
# Where reservation emails are delivered (can be the same as SMTP_USER)
BOOKING_EMAIL_TO=your-inbox@gmail.com
# Optional "From" display name (must be allowed for that SMTP account)
# BOOKING_EMAIL_FROM=Latana Cafe <your-account@gmail.com>
